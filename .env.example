# Local development environment — COPY to .env and fill in values
# NEVER commit .env to git (it's in .gitignore)

# Database (local Docker or native Postgres)
DATABASE_URL=postgresql+asyncpg://ss_app:dev@localhost:5432/sorcerers_stone

# Redis (local Docker or native)
REDIS_URL=redis://localhost:6379/0

# Application
APP_ENV=development
LOG_LEVEL=DEBUG
LOG_JSON=false

# Session
SESSION_SECRET=local-dev-session-secret-change-for-production

# Field encryption key (32 bytes base64 — generate with: openssl rand -base64 32)
FIELD_ENC_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Plaid Sandbox credentials — get from https://dashboard.plaid.com/team/keys
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_sandbox_secret_here
PLAID_ENV=sandbox
