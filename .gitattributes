# Normalize line endings to LF in the repo; checkout as-is on Windows
* text=auto eol=lf

# Force LF for these file types regardless of OS
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.py        text eol=lf
*.sh        text eol=lf
*.txt       text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.env       text eol=lf

# Binary — no line-ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.zip       binary
*.gz        binary
*.tar       binary
