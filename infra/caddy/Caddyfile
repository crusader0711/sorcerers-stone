# Caddyfile — The Sorcerer's Stone
# Deploy to: /mnt/user/appdata/sorcerers-stone/caddy/Caddyfile
# Ref: .kiro/specs/phase-1-architecture/design.md §3

{
    # Global options
    admin off                          # disable Caddy admin API on 2019 (not needed)
    servers {
        protocols h2 h1                # HTTP/2 + HTTP/1.1; no HTTP/3 (QUIC) on LAN
        timeouts {
            read_body   10s
            read_header 10s
            write       30s
            idle        120s
        }
    }
    # Auto-HTTPS via internal CA (mkcert-style); replace with acme if using real cert
    # For LAN-only deployment, Caddy's internal CA issues a self-signed cert.
    # Trust the CA once on each client: https://caddyserver.com/docs/automatic-https#local-https
}

# ── Main dashboard site ───────────────────────────────────────────────────────
# Access via: https://<UNRAID-IP>:8443  or  https://dashboard.home:8443
# "dashboard.home" requires a local DNS entry pointing to UNRAID IP.

:8443 {
    tls internal {
        # Caddy generates a local CA and issues a cert automatically.
        # On first access, browser will warn — add the Caddy CA to your trust store.
        # CA cert location: /mnt/user/appdata/sorcerers-stone/caddy/data/caddy/pki/
    }

    # ── Security headers (INV-4) ─────────────────────────────────────────────
    header {
        # Force TLS — clients that land here already have it; belt-and-suspenders
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

        # Prevent clickjacking
        X-Frame-Options "DENY"

        # Prevent MIME sniffing
        X-Content-Type-Options "nosniff"

        # No referrer leakage
        Referrer-Policy "no-referrer"

        # CSP: self-only, no external CDNs (INV-1 + REQ-DASH-3)
        Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'"

        # Disable browser features not needed by a financial dashboard
        Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=(), usb=()"

        # Remove server fingerprint
        -Server

        # Prevent caching of sensitive financial data in proxies
        Cache-Control "no-store, no-cache, must-revalidate"
    }

    # ── Rate limiting on login endpoint ──────────────────────────────────────
    # First-layer guard before FastAPI Redis rate limiter (defence-in-depth)
    # Requires caddy-ratelimit module (available in xcaddy build or caddy:2 + modules image)
    # If using plain caddy:2-alpine, remove this block and rely on FastAPI layer only.
    # @login_path {
    #     path /auth/login
    # }
    # rate_limit @login_path 10r/m

    # ── Proxy to FastAPI app ──────────────────────────────────────────────────
    # Phase 1: app not running yet — proxy will return 502 (expected)
    # Phase 2+: ss-app container on ss-net at port 8000
    reverse_proxy ss-app:8000 {
        health_uri      /healthz
        health_interval 30s
        health_timeout  5s

        # Forward real client IP for audit logging
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Request-ID {http.request.uuid}
    }

    # ── Static files (served by FastAPI in Phase 1; could move to Caddy later) ─
    # encode gzip zstd

    # ── Logging ──────────────────────────────────────────────────────────────
    log {
        output file /data/caddy-access.log {
            roll_size     100MiB
            roll_keep     5
            roll_keep_for 720h
        }
        format json
        level  INFO
    }
}

# ── Metrics endpoint (internal only) ─────────────────────────────────────────
# /metrics served by FastAPI on the internal network; not exposed via Caddy.
# Prometheus scrapes ss-app:8000/metrics directly within ss-net.
